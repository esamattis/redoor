#!/bin/bash
set -eu

silent_unless_error() {
    local tmpfile=$(mktemp -t redoor-test.XXX)
    echo -n "> $*"
    local exit_code=0
    "$@" >"$tmpfile" 2>&1 || exit_code=$?
    if [ $exit_code -ne 0 ]; then
        echo "❌ failed with exit code $exit_code: $*"
        echo
        cat "$tmpfile"
        exit $exit_code
    fi
    echo " ✅"
    rm -f "$tmpfile"
    return $exit_code
}

silent_unless_error cargo test
silent_unless_error pnpm run build
silent_unless_error cargo build
silent_unless_error pnpm run test
silent_unless_error pnpm run types
silent_unless_error pnpm run playwright
silent_unless_error pnpm run lint
silent_unless_error pnpm run format:check
silent_unless_error cargo fmt -- --check
silent_unless_error cargo clippy
