{
    "name": "redoor-ui",
    "private": true,
    "type": "module",
    "scripts": {
        "vite": "vite ./ui",
        "build": "vite build ./ui",
        "check": "run-s types lint",
        "types": "tsc -p tsconfig.json",
        "format": "cd ui && prettier --write .",
        "format:check": "cd ui && prettier --check .",
        "playwright": "playwright test --reporter=line --config ui/playwright.config.ts",
        "lint": "cd ui && oxlint",
        "dev": "pnpm run --parallel --stream \"/^redoor:/\"",
        "redoor:server": "./scripts/redoor",
        "redoor:agent1": "./scripts/redoor-agent agent1_src",
        "redoor:agent2": "mkdir -p dev_agents/agent2 && cd dev_agents/agent2 && ../../scripts/redoor-agent agent2_custom",
        "lint:fix": "oxlint --fix",
        "preview": "vite preview",
        "playwright-server:vite": "pnpm exec vite preview ./ui --host 127.0.0.1 --port 4000",
        "playwright-server:server": "./target/debug/redoor",
        "playwright-server:agent1": "./target/debug/redoor-agent ws://127.0.0.1:3000/ws --name agent1_src",
        "playwright-server:agent2": "mkdir -p dev_agents/agent2 && cd dev_agents/agent2 && ../../target/debug/redoor-agent ws://127.0.0.1:3000/ws --name agent2_custom",
        "test": "vitest run --config vitest.config.ts tests"
    },
    "dependencies": {
        "@playwright/mcp": "^0.0.56",
        "@tailwindcss/vite": "^4.0.6",
        "@tanstack/react-devtools": "^0.7.0",
        "@tanstack/react-query": "^5.91.3",
        "@tanstack/react-router": "^1.132.0",
        "@tanstack/react-router-devtools": "^1.132.0",
        "@tanstack/router-plugin": "^1.132.0",
        "jotai": "^2.18.1",
        "lucide-react": "^0.545.0",
        "oxlint": "^1.39.0",
        "prettier": "^3.8.0",
        "react": "^19.2.0",
        "react-dom": "^19.2.0",
        "tailwindcss": "^4.0.6"
    },
    "devDependencies": {
        "@playwright/test": "^1.57.0",
        "@tanstack/devtools-vite": "^0.3.11",
        "@testing-library/dom": "^10.4.0",
        "@testing-library/react": "^16.2.0",
        "@types/node": "^22.10.2",
        "@types/react": "^19.2.0",
        "@types/react-dom": "^19.2.0",
        "@vitejs/plugin-react": "^5.0.4",
        "jsdom": "^27.0.0",
        "typescript": "^5.7.2",
        "vite": "^7.1.7",
        "vitest": "^3.0.5",
        "web-vitals": "^5.1.0"
    }
}
